<h1>Einstellungen</h1>

<%# Reiner Anzeige-Filter (Intent 57, ersetzt den festen Blues/Fusion-Enum aus Intent 54) -
    schraenkt ein, was auf Tracks/Playlists/Artists und in der Suche sichtbar ist. Aendert nichts
    am Spotify-Sync (der importiert weiterhin alle Playlists, die einer Library entsprechen). %>
<%= form_with model: current_user, url: settings_path, method: :patch, local: true do |f| %>
  <div class="mb-3">
    <label class="form-label d-block">Aktive Bibliothek</label>
    <div class="form-check">
      <%= f.radio_button :active_library_id, "", class: "form-check-input", id: "library_all" %>
      <%= f.label :active_library_id, "Alle", value: "", for: "library_all", class: "form-check-label" %>
    </div>
    <% @libraries.each do |library| %>
      <div class="form-check">
        <%= f.radio_button :active_library_id, library.id, class: "form-check-input", id: "library_#{library.id}" %>
        <%= f.label :active_library_id, library.name, value: library.id, for: "library_#{library.id}", class: "form-check-label" %>
      </div>
    <% end %>
  </div>
  <%= f.submit "Speichern", class: "btn btn-outline-secondary" %>
<% end %>
