<%= form_with model: library, local: true do |f| %>
  <% if library.errors.any? %>
    <div class="alert alert-danger">
      <%= library.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :keyword, "Stichwort", class: "form-label" %>
    <%= f.text_field :keyword, class: "form-control" %>
    <div class="form-text">
      Playlists, deren Name auf Spotify dieses Stichwort enthält (gross-/kleinschreibungsunabhängig),
      werden automatisch dieser Bibliothek zugeordnet.
    </div>
  </div>

  <%= f.submit "Speichern", class: "btn btn-outline-secondary" %>
<% end %>
