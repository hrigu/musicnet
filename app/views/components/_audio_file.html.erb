<%# Kein eigenes <audio> mehr pro Zeile (Intent 40) - der Play-Button dispatcht nur ein Event,
    die eigentliche Wiedergabe laeuft im dauerhaften globalen Player (layouts/_audio_player).
    Play-Button zeigt bewusst immer "▶", nicht den Play/Pause-Status - der wird nur in der
    globalen Leiste angezeigt. Das Einreihen in die Queue (Intent 41/42) ist seit Intent 42 ein
    normaler POST-Request statt eines Stimulus-Events, da die Queue jetzt Server-Zustand ist.
    Die id erlaubt QueueEntriesController, die "in Queue"-Markierung per Turbo-Stream-Broadcast
    sofort zu aktualisieren, statt erst beim naechsten Laden der Seite (Intent 42 Nachtrag). %>
<div id="<%= dom_id(track, :audio_file) %>" class="d-flex align-items-center gap-2 audio-file-buttons">
  <% if track.track_path %>
    <%# Bleibt auch fuer bereits gequeueste Tracks sichtbar (anders als Play/+) - Vorhoeren ist
        vom Queue-Status unabhaengig sinnvoll, z.B. nochmals reinhoeren kurz bevor der Track
        dran ist (Intent 51). %>
    <button type="button" class="btn btn-sm btn-outline-secondary rounded-circle" title="Vorhören (separater Kanal)"
            data-controller="audio-trigger"
            data-audio-trigger-url-value="<%= stream_track_path(track.id) %>"
            data-audio-trigger-name-value="<%= track.name %>"
            data-action="audio-trigger#cue">
      🎧
    </button>
    <% if queued_track_ids.include?(track.id) %>
      <%# Ersetzt bewusst die Buttons statt daneben zu stehen - Platzgrund, und ein bereits
          gequeueter Track muss nicht nochmals eingereiht werden. %>
      <span class="badge bg-secondary" title="Bereits in der Queue">in Queue</span>
    <% else %>
      <button type="button" class="btn btn-sm btn-outline-secondary rounded-circle" title="Abspielen"
              data-controller="audio-trigger"
              data-audio-trigger-url-value="<%= stream_track_path(track.id) %>"
              data-audio-trigger-name-value="<%= track.name %>"
              data-action="audio-trigger#play">
        ▶
      </button>
      <%= button_to "+", queue_entries_path(track_id: track.id), method: :post,
                    class: "btn btn-sm btn-outline-secondary rounded-circle", title: "Zur Queue hinzufügen" %>
    <% end %>
  <% else %>
    <span class="badge bg-danger">kein File</span>
  <% end %>
</div>
