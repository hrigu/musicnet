<div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
  <div>
    <h1 class="mb-1"><%= @track.name %></h1>
    <div class="text-muted">
      Album: <%= @track.album.name %>
      <% if @track.album.release_date %>
        von <%= l(@track.album.release_date) %>
      <% end %>
    </div>
  </div>
  <%= render partial: 'components/audio_file', locals: { track: @track } %>
</div>

<% if @track.track_path.blank? %>
  <%# Solange keine lokale Datei existiert, bleibt Spotify die einzige Anhoer-Moeglichkeit
      (Intent 64) - sobald heruntergeladen, uebernimmt der Play-Button oben. %>
  <div class="my-3">
    <div class="mb-2"><%= link_to "Track in Spotify hören", @track.url, target: "_blank", rel: "noopener" %></div>
    <%= render partial: 'components/spotify_player', locals: { track: @track } %>
  </div>
<% end %>

<div class="d-flex flex-wrap gap-4 my-3">
  <div>
    <div class="text-muted small mb-1">Dauer</div>
    <span><%= @track.dauer %></span>
  </div>
  <div>
    <div class="text-muted small mb-1">Genre</div>
    <% if @track.genre.present? %>
      <%= link_to genre_badge(@track.genre), tracks_path(q: %(genre:"#{@track.genre}")) %>
    <% else %>
      <%= genre_badge(@track.genre) %>
    <% end %>
  </div>
  <% if @track.energy %>
    <div style="min-width: 160px">
      <div class="text-muted small mb-1">Energie</div>
      <%= track_meter(engergie_to_view(@track.energy), variant: "warning") %>
    </div>
  <% end %>
  <% if @track.tempo %>
    <div>
      <div class="text-muted small mb-1">Tempo</div>
      <span><%= tempo_to_view(@track.tempo) %> <span class="small text-muted">BPM</span></span>
    </div>
  <% end %>
  <% if @track.displayed_file_name.present? %>
    <div>
      <div class="text-muted small mb-1">Datei</div>
      <span>
        <%= @track.displayed_file_name %>
        <% unless @track.file_name_from_db? %>
          <span class="text-muted small">(nicht in DB gespeichert)</span>
        <% end %>
      </span>
    </div>
  <% end %>
</div>

<div class="mb-3">
  <div class="text-muted small mb-1">Künstler</div>
  <div class="d-flex flex-wrap gap-2">
    <% @track.artists.each do |a| %>
      <%= link_to a.name, artist_path(a.id), class: "d-inline-block" %>
    <% end %>
  </div>
</div>

<div class="mb-3">
  <div class="text-muted small mb-1">Tags</div>
  <% if @track.track_tags.empty? %>
    <span class="text-muted">–</span>
  <% else %>
    <div class="d-flex flex-column gap-1">
      <% track_tags_by_category(@track).each do |category, track_tags| %>
        <div class="d-flex align-items-center flex-wrap gap-2">
          <span class="text-muted small" style="min-width: 9rem"><%= category.name %></span>
          <% track_tags.each do |tt| %>
            <span class="d-inline-flex align-items-center gap-1">
              <%= link_to track_tag_badge(tt), tracks_path(q: %(tag:"#{tt.tag.name}")) %>
              <span class="text-muted small"><%= l(tt.created_at.to_date) %></span>
              <%= button_to "×", track_tag_path(tt), method: :delete, class: "btn btn-sm btn-link p-0",
                    data: { turbo_confirm: "Tag \"#{tt.tag.name}\" von diesem Track entfernen?" } %>
            </span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="mt-2" data-controller="tag-assign">
    <button type="button" class="btn btn-sm btn-outline-secondary" data-action="tag-assign#open"
            data-tag-assign-target="openButton">
      + Tag hinzufügen
    </button>

    <%= form_with url: track_tags_path, method: :post, local: true,
          class: "border rounded p-3 mt-2 d-none", data: { tag_assign_target: "panel" } do %>
      <%= hidden_field_tag :track_id, @track.id %>
      <%= hidden_field_tag :tag_id, "", data: { tag_assign_target: "tagIdField" } %>
      <%= hidden_field_tag :tag_name, "", data: { tag_assign_target: "tagNameField" } %>
      <%= hidden_field_tag :category_id, "", data: { tag_assign_target: "categoryIdField" } %>

      <div data-tag-assign-target="stepSearch">
        <label class="form-label small">Tag-Name</label>
        <div class="position-relative">
          <%= text_field_tag :tag_search, nil, autocomplete: "off", placeholder: "z.B. traurig",
                class: "form-control form-control-sm",
                data: { tag_assign_target: "searchInput",
                        action: "input->tag-assign#onInput keydown->tag-assign#onSearchKeydown" } %>
          <div class="list-group position-absolute w-100 shadow-sm d-none" style="z-index: 10;"
               data-tag-assign-target="results"></div>
        </div>
      </div>

      <div data-tag-assign-target="stepCategory" class="d-none mt-2">
        <label class="form-label small">
          Kategorie für den neuen Tag „<span data-tag-assign-target="newTagLabel"></span>“
        </label>
        <select class="form-select form-select-sm" data-tag-assign-target="categorySelect"
                data-action="keydown.enter->tag-assign#confirmCategory">
          <% Category.order(:name).each do |category| %>
            <option value="<%= category.id %>"><%= category.name %></option>
          <% end %>
        </select>
        <div class="d-flex gap-2 mt-2">
          <button type="button" class="btn btn-sm btn-outline-secondary" data-action="tag-assign#confirmCategory">
            Weiter
          </button>
          <button type="button" class="btn btn-sm btn-link text-muted" data-action="tag-assign#backToSearch">
            Zurück
          </button>
        </div>
      </div>

      <div data-tag-assign-target="stepStrength" class="d-none mt-2">
        <label class="form-label small">
          Stärke für <strong data-tag-assign-target="chosenTagLabel"></strong> (1–10)
        </label>
        <%= number_field_tag :strength, 5, min: 1, max: 10, class: "form-control form-control-sm", style: "max-width: 6rem;",
              data: { tag_assign_target: "strengthInput" } %>
        <div class="d-flex gap-2 mt-2">
          <button type="submit" class="btn btn-sm btn-outline-secondary">Hinzufügen</button>
          <button type="button" class="btn btn-sm btn-link text-muted" data-action="tag-assign#backToSearch">
            Zurück, anderes Tag wählen
          </button>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="mb-3">
  <div class="text-muted small mb-1">Playlists die diesen Track enthalten</div>
  <div class="d-flex flex-wrap gap-3">
    <% @track.playlist_tracks.each do |pt| %>
      <div class="d-flex align-items-center gap-2 border rounded-pill px-2 py-1">
        <%= link_to playlist_badge(pt.playlist, label: pt.playlist.name), playlist_path(pt.playlist.id) %>
        <% if pt.added_at %>
          <span class="text-muted small"><%= l(pt.added_at.to_date) %></span>
        <% end %>
        <%= button_to "×", playlist_track_path(pt), method: :delete, class: "btn btn-sm btn-link p-0",
                      data: { turbo_confirm: "Track aus \"#{pt.playlist.name}\" entfernen?" } %>
      </div>
    <% end %>
  </div>

  <% if @addable_playlists.any? %>
    <%= form_with url: playlist_tracks_path(track_id: @track.id), local: true,
                  class: "d-flex align-items-center gap-2 mt-2" do %>
      <%= select_tag :playlist_id, options_for_select(@addable_playlists.map { |p| [p.name, p.id] }),
                     class: "form-select form-select-sm w-auto" %>
      <%= submit_tag "Zu Playlist hinzufügen", class: "btn btn-sm btn-outline-secondary" %>
    <% end %>
  <% end %>
</div>
