<div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
  <div class="d-flex align-items-start gap-3">
    <% if @track.track_path.present? %>
      <%= image_tag cover_track_path(@track), alt: "", class: "rounded shadow-sm", width: 96, height: 96,
            onerror: "this.remove()" %>
    <% end %>
    <div>
      <h1 class="mb-1"><%= @track.name %></h1>
      <div class="text-muted">
        Album: <%= @track.album.name %>
        <% if @track.album.release_date %>
          von <%= l(@track.album.release_date) %>
        <% end %>
      </div>
    </div>
  </div>
  <%= render partial: 'components/audio_file', locals: { track: @track } %>
</div>

<% if @track.track_path.blank? %>
  <%# Solange keine lokale Datei existiert, bleibt Spotify die einzige Anhoer-Moeglichkeit
      (Intent 64) - sobald heruntergeladen, uebernimmt der Play-Button oben. %>
  <div class="my-3">
    <div class="mb-2"><%= link_to "Track in Spotify hören", @track.url, target: "_blank", rel: "noopener" %></div>
    <%= render partial: 'components/spotify_player', locals: { spotify_id: @track.spotify_id } %>
  </div>
<% end %>

<div class="d-flex flex-wrap gap-4 my-3">
  <div>
    <div class="text-muted small mb-1">Dauer</div>
    <span><%= @track.dauer %></span>
  </div>
  <div>
    <div class="text-muted small mb-1">Genre</div>
    <% if @track.genre.present? %>
      <%= link_to genre_badge(@track.genre), tracks_path(q: %(genre:"#{@track.genre}")) %>
    <% else %>
      <%= genre_badge(@track.genre) %>
    <% end %>
  </div>
  <% if @track.energy %>
    <div style="min-width: 160px">
      <div class="text-muted small mb-1">Energie</div>
      <%= track_meter(engergie_to_view(@track.energy), variant: "warning") %>
    </div>
  <% end %>
  <% if @track.tempo %>
    <div>
      <div class="text-muted small mb-1">Tempo</div>
      <span><%= tempo_to_view(@track.tempo) %> <span class="small text-muted">BPM</span></span>
    </div>
  <% end %>
  <% if @track.displayed_file_name.present? %>
    <div>
      <div class="text-muted small mb-1">Datei</div>
      <span>
        <%= @track.displayed_file_name %>
        <% unless @track.file_name_from_db? %>
          <span class="text-muted small">(nicht in DB gespeichert)</span>
        <% end %>
      </span>
    </div>
  <% end %>
</div>

<div class="mb-3">
  <div class="text-muted small mb-1">Künstler</div>
  <div class="d-flex flex-wrap gap-2">
    <% @track.artists.each do |a| %>
      <%= link_to a.name, artist_path(a.id), class: "d-inline-block" %>
    <% end %>
  </div>
</div>

<%# Eigene Partial + eigener dom_id (:track_tags_panel), damit TrackTagsController#create diesen
    Bereich per Turbo-Stream gezielt ersetzen kann (siehe track_tags/create.turbo_stream.erb) -
    ohne data-turbo="false" auf dem Formular, das fruher noetig war, weil der Turbo-Stream nur die
    Tags-Zelle der /tracks-Liste kannte und auf dieser Seite ein stiller No-Op gewesen waere. Das
    deaktivierte aber Turbo Drive fuer den ganzen Formular-Submit und loeste dadurch einen echten
    Hard-Reload der Seite aus - der killt auch den data-turbo-permanent Audio-Player, da der nur
    ueber Turbo-Drive-Visits hinweg ueberlebt, nicht ueber einen klassischen Browser-Reload (siehe
    Diary/Intent 87 Bugfix: Wiedergabe stoppte beim Tag-Zuweisen waehrend ein Track lief). %>
<%= render partial: "tracks/tag_panel", locals: { track: @track, recent_tag_suggestions: @recent_tag_suggestions } %>

<div class="mb-3">
  <div class="text-muted small mb-1">Playlists die diesen Track enthalten</div>
  <div class="d-flex flex-wrap gap-3">
    <% @track.playlist_tracks.each do |pt| %>
      <div class="d-flex align-items-center gap-2 border rounded-pill px-2 py-1">
        <%= link_to playlist_badge(pt.playlist, label: pt.playlist.name), playlist_path(pt.playlist.id) %>
        <% if pt.added_at %>
          <span class="text-muted small"><%= l(pt.added_at.to_date) %></span>
        <% end %>
        <%= button_to "×", playlist_track_path(pt), method: :delete, class: "btn btn-sm btn-link p-0",
                      data: { turbo_confirm: "Track aus \"#{pt.playlist.name}\" entfernen?" } %>
      </div>
    <% end %>
  </div>

  <% if @addable_playlists.any? %>
    <%= form_with url: playlist_tracks_path(track_id: @track.id), local: true,
                  class: "d-flex align-items-center gap-2 mt-2" do %>
      <%= select_tag :playlist_id, options_for_select(@addable_playlists.map { |p| [p.name, p.id] }),
                     class: "form-select form-select-sm w-auto" %>
      <%= submit_tag "Zu Playlist hinzufügen", class: "btn btn-sm btn-outline-secondary" %>
    <% end %>
  <% end %>
</div>

<%# Rangliste verwandter Tracks (Intent 84, Stufe 1 - bewusst noch keine Karte, siehe
    RelatedTracksFinder). Eigener Turbo-Frame, damit das Kategorie-Filterformular nur diesen
    Abschnitt neu laedt, nicht die ganze Seite. %>
<%= turbo_frame_tag dom_id(@track, :related_tracks), class: "d-block mb-3" do %>
  <div class="text-muted small mb-1">Verwandte Tracks</div>

  <%# Kein local: true - dieses GET-Formular soll bewusst als Turbo-Frame-Request laufen (Default
      innerhalb eines turbo_frame_tag), damit nur dieser Abschnitt neu laedt, nicht lokal:true
      waere hier ohnehin wirkungslos, siehe die form_with-Falle bei Intent 83. %>
  <%= form_with url: track_path(@track), method: :get,
        class: "d-flex flex-wrap align-items-center gap-3 mb-2" do %>
    <% @categories.each do |category| %>
      <div class="form-check form-check-inline mb-0">
        <%= check_box_tag "related_category_ids[]", category.id,
              params[:related_category_ids]&.include?(category.id.to_s),
              id: "related_category_#{category.id}", class: "form-check-input" %>
        <%= label_tag "related_category_#{category.id}", category.name, class: "form-check-label small" %>
      </div>
    <% end %>

    <%# Zusaetzliche, nicht tag-basierte Attribute (Intent 84 Nachtrag 5) - jedes einzeln an-/
        abwaehlbar, mit einem Gewichtsfaktor (Default 1.0), um ihren Einfluss auf die Punktzahl
        relativ zu Tags und den anderen Attributen zu steuern (z.B. Tempo hoch gewichten, um
        vor allem mixbare Anschlusstracks zu finden). %>
    <% related_attribute_keys.each do |key| %>
      <div class="d-flex align-items-center gap-1">
        <div class="form-check form-check-inline mb-0">
          <%= check_box_tag "related_attribute_ids[]", key, related_attribute_enabled?(key),
                id: "related_attribute_#{key}", class: "form-check-input" %>
          <%= label_tag "related_attribute_#{key}", related_attribute_label(key), class: "form-check-label small" %>
        </div>
        <%= number_field_tag "related_attribute_weights[#{key}]", related_attribute_weight(key),
              step: 0.5, min: 0, class: "form-control form-control-sm", style: "width: 4.5rem;",
              title: "Gewicht für #{related_attribute_label(key)}" %>
      </div>
    <% end %>

    <%= submit_tag "Filtern", class: "btn btn-sm btn-outline-secondary" %>
  <% end %>

  <%# Macht sichtbar, dass die Rangliste bei einem Punktegleichstand willkuerlich gekuerzt wurde,
      statt das stillschweigend zu verstecken (Intent 84 Nachtrag - konkreter Anlass: ein Track mit
      nur 2 Tags in der gewaehlten Kategorie hatte weit mehr als 10 gleichauf liegende Treffer). %>
  <% if @related_additional_tied_count.positive? %>
    <div class="alert alert-warning py-1 px-2 small mb-2">
      Nur <%= @related_active_comparison_count %>
      <%= @related_active_comparison_count == 1 ? "Attribut fliesst" : "Attribute fliessen" %>
      hier in die Berechnung ein - die Rangliste ist entsprechend wenig differenzierend.
      Es gibt <%= @related_additional_tied_count %> weitere Tracks mit derselben Punktzahl wie der
      letzte angezeigte Treffer, die hier nicht angezeigt werden.
    </div>
  <% end %>

  <% if @related_tracks.empty? %>
    <span class="text-muted">–</span>
  <% else %>
    <table class="table table-sm">
      <thead>
        <tr>
          <th scope="col">Track</th>
          <th scope="col">Künstler</th>
          <th scope="col">Tags</th>
          <th scope="col" class="text-end">Punkte</th>
          <th scope="col"></th>
        </tr>
      </thead>
      <tbody>
        <% @related_tracks.each do |result| %>
          <tr>
            <td>
              <%= link_to result[:track].name, track_path(result[:track]) %>
              <div class="text-muted small"><%= related_track_score_breakdown(result[:contributions]) %></div>
            </td>
            <td><%= artist_names_for(result[:track]) %></td>
            <td>
              <%# Nur Tags aus Kategorien, die auch der Ausgangstrack traegt (@relevant_category_ids)
                  - andere Tags des verwandten Tracks waren fuer die Berechnung nicht relevant und
                  wuerden nur unnoetigen Noise erzeugen (Intent 84 Nachtrag). %>
              <div class="d-flex flex-wrap gap-1">
                <% result[:track].track_tags.select { |tt| @relevant_category_ids.include?(tt.tag.category_id) }.each do |tt| %>
                  <%= track_tag_badge(tt) %>
                <% end %>
              </div>
            </td>
            <td class="text-end text-muted"><%= result[:score] %></td>
            <td><%= render partial: "components/audio_file", locals: { track: result[:track] } %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
<% end %>
