<h1>Zuletzt gespielt</h1>

<%# Gleicher "downloads"-Kanal wie tracks/index.html.erb (Intent 39/40) - ohne diese Subscription
    + das Ziel-Element hier bekommt man vom Import+Download eines Spotify-Tracks (Intent 88) keine
    Rueckmeldung, weil der Broadcast zwar ankommt, aber kein Element dieser Seite ihn auffaengt. %>
<%= turbo_stream_from "downloads" %>
<div id="download-log" class="mb-3"></div>

<ul class="nav nav-tabs mb-3">
  <li class="nav-item">
    <%= link_to "Musicnet", recently_played_index_tracks_path(tab: "musicnet"),
          class: ["nav-link", ("active" if @active_recently_played_tab == "musicnet")].compact.join(" ") %>
  </li>
  <li class="nav-item">
    <%= link_to "Spotify", recently_played_index_tracks_path(tab: "spotify"),
          class: ["nav-link", ("active" if @active_recently_played_tab == "spotify")].compact.join(" ") %>
  </li>
</ul>

<% if @active_recently_played_tab == "musicnet" %>
  <div class="table-responsive rounded border">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th scope="col">Zeit</th>
          <th scope="col">Titel</th>
          <th scope="col">Künstler</th>
          <th scope="col">Album</th>
          <th scope="col">Ort</th>
        </tr>
      </thead>
      <tbody>
        <% if @musicnet_session_groups.any? %>
          <% @musicnet_session_groups.each do |session_playbacks| %>
            <% session_start = session_playbacks.last.played_at %>
            <% session_end = session_playbacks.first.played_at %>
            <% session_location = session_playbacks.find { |p| p.latitude && p.longitude } %>
            <tr class="table-light dj-session-header">
              <td colspan="5">
                <strong>Session</strong>
                <span class="text-muted">
                  <%= l(session_start, format: :short) %>–<%= l(session_end, format: :time_only) %> Uhr ·
                  <%= pluralize(session_playbacks.size, "Titel") %>
                  <% if session_location %>
                    · <%= playback_location_label(session_location) %>
                  <% end %>
                </span>
              </td>
            </tr>
            <% session_playbacks.each do |playback| %>
              <tr>
                <td class="text-muted"><%= l(playback.played_at) %></td>
                <td><%= link_to playback.track.name, track_path(playback.track) %></td>
                <td><%= playback.track.artists.map(&:name).join(", ") %></td>
                <td><%= playback.track.album.name %></td>
                <td class="text-muted"><%= playback_location_label(playback) || "–" %></td>
              </tr>
            <% end %>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" class="text-muted">Noch keine lokal gespeicherten Musicnet-Playbacks.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <%# Spotifys /recently-played liefert grundsaetzlich nie mehr als ein rollierendes Fenster von
      ca. 50 Wiedergaben zurueck (auch in der Spotify-App selbst so begrenzt) - kein Verhalten
      dieser App. Der Aufruf fragt bereits das Maximum an (limit: 50). %>
  <p class="text-muted small">
    Spotify liefert maximal die letzten 50 Wiedergaben zurück (eigenes, rollierendes Fenster -
    keine Beschränkung durch Musicnet).
  </p>
  <div class="table-responsive rounded border">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th scope="col">Zeit</th>
          <th scope="col">Titel</th>
          <th scope="col">Künstler</th>
          <th scope="col">Album</th>
          <th scope="col">Bekanntheit</th>
          <th scope="col">Musicnet</th>
        </tr>
      </thead>
      <tbody>
        <% if @spotify_tracks.any? %>
          <% @spotify_tracks.each do |playback| %>
            <% local_track = @local_tracks_by_spotify_id[playback.id] %>
            <tr>
              <td class="text-muted"><%= l(Time.zone.parse(playback.played_at)) %></td>
              <td>
                <% if local_track %>
                  <%= link_to playback.name, track_path(local_track) %>
                <% else %>
                  <%= playback.name %>
                <% end %>
              </td>
              <td><%= playback.artists.map(&:name).join(", ") %></td>
              <td><%= playback.album.name %></td>
              <td class="text-muted"><%= playback.popularity %></td>
              <td>
                <% if local_track %>
                  <span class="badge text-bg-secondary">in Musicnet</span>
                <% else %>
                  <%= button_to "Herunterladen", import_from_spotify_tracks_path(spotify_track_id: playback.id),
                        method: :post, class: "btn btn-sm btn-outline-secondary" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="6" class="text-muted">Keine Spotify-Playbacks gefunden.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
