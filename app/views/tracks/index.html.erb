<div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
  <h1 class="mb-0">Meine Tracks</h1>
  <div class="d-flex gap-2">
    <%= link_to("Download Files", download_tracks_path, data: { turbo_method: :post }, class: "btn btn-outline-secondary") %>
  </div>
</div>

<%# Bewusst ausserhalb des turbo_frame_tag "tracks": Suche/Sortierung/Pagination ersetzen dessen
    Inhalt komplett - der Live-Log wuerde sonst bei jeder Aktion verloren gehen. %>
<%= turbo_stream_from "downloads" %>
<div id="download-log" class="mb-3"></div>

<%= turbo_frame_tag "tracks" do %>
  <%= form_with url: tracks_path, method: :get, id: "tracks-search", class: "mb-3" do %>
    <%= hidden_field_tag :sort, params[:sort] %>
    <%= hidden_field_tag :direction, params[:direction] %>
    <div class="d-flex gap-2">
      <div class="position-relative flex-grow-1" data-controller="search-suggestions">
        <%= text_field_tag :q, params[:q], placeholder: 'z.B. genre:jazz bpm:80..100 playlist:"Name"',
              autocomplete: "off", class: "form-control search-query-input w-100",
              data: {
                search_suggestions_target: "input",
                action: "input->search-suggestions#onInput"
              } %>
        <div class="search-suggestions-list dropdown-menu" data-search-suggestions-target="list"></div>
      </div>
      <%= submit_tag "Suchen", class: "btn btn-outline-secondary flex-shrink-0" %>
    </div>
    <small class="search-syntax-hint form-text text-muted d-block mt-1">
      Felder: <code>artist:</code> <code>album:</code> <code>genre:</code> <code>playlist:</code>
      <code>bpm:</code> <code>energy:</code> <code>popularity:</code> <code>year:</code> &middot;
      Beispiele: <code>genre:jazz,fusion</code> <code>bpm:80..100</code> <code>-genre:blues</code>
      <code>playlist:"Fusion Abende"</code>
    </small>
  <% end %>

  <%= render 'tracks', tracks: @tracks %>

  <%== @pagy.series_nav(:bootstrap) %>
<% end %>
