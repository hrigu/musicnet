<div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
  <h1 class="mb-0">Kategorien &amp; Tags</h1>
  <%= link_to("Neue Kategorie", new_category_path, class: "btn btn-outline-secondary") %>
</div>

<% @categories.each do |category| %>
  <div class="mt-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
      <h2 class="h5 mb-2">
        <%= category.name %>
        <% if category.hidden_for_assignment? %>
          <span class="badge text-bg-secondary category-hidden-badge">ausgeblendet</span>
        <% end %>
      </h2>
      <div class="d-flex gap-2">
        <%= link_to("Tag hinzufügen", new_category_tag_path(category), class: "btn btn-sm btn-outline-secondary") %>
        <%= link_to("Bearbeiten", edit_category_path(category), class: "btn btn-sm btn-outline-secondary") %>
        <%= button_to "Löschen", category_path(category), method: :delete,
              data: { turbo_confirm: "Kategorie \"#{category.name}\" wirklich löschen? Enthaltene Tags werden mitgelöscht." },
              class: "btn btn-sm btn-outline-danger" %>
      </div>
    </div>

    <table class="table table-sm">
      <thead>
        <tr>
          <th scope="col">Name</th>
          <th scope="col">Alias-Stichwörter</th>
          <th scope="col"></th>
        </tr>
      </thead>
      <tbody>
        <% category.tags.order(:name).each do |tag| %>
          <tr>
            <td>
              <%= tag_badge(tag) %>
              <% unless tag.assignable? %>
                <span class="badge text-bg-warning tag-assignable-badge">gesperrt</span>
              <% end %>
            </td>
            <td class="text-muted"><%= tag.aliases %></td>
            <td class="text-end">
              <%= link_to "Bearbeiten", edit_tag_path(tag), class: "btn btn-sm btn-outline-secondary" %>
              <%= button_to "Löschen", tag_path(tag), method: :delete,
                    data: { turbo_confirm: "Tag \"#{tag.name}\" wirklich löschen?" },
                    class: "btn btn-sm btn-outline-danger" %>
            </td>
          </tr>
        <% end %>
        <% if category.tags.empty? %>
          <tr><td colspan="3" class="text-muted">Keine Tags.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
