
<div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
  <h1 class="mb-0"><%= @playlist.name %></h1>
  <div class="d-flex gap-2">
    <% if all_tracks_downloaded?(@playlist_tracks) %>
      <button type="button" class="btn btn-outline-secondary" disabled title="Alle Tracks sind bereits heruntergeladen">Download Tracks</button>
    <% else %>
      <%= link_to("Download Tracks", download_playlist_path(@playlist.id), data: { turbo_method: :post }, class: "btn btn-outline-secondary") %>
    <% end %>
    <%= link_to("Playlist aktualisieren", refresh_playlist_path(@playlist.id), data: { turbo_method: :post }, class: "btn btn-outline-secondary") %>
  </div>
</div>
<p class="text-muted small mb-3">Zuletzt aktualisiert: <%= l(@playlist.updated_at) %></p>

<% if flash[:refresh_added] || flash[:refresh_removed] %>
  <div class="alert alert-info mt-3">
    <% if flash[:refresh_added].blank? && flash[:refresh_removed].blank? %>
      Keine Änderungen — die Playlist ist auf dem aktuellen Stand.
    <% else %>
      <% if flash[:refresh_added].present? %>
        <strong>Hinzugekommen:</strong>
        <ul class="mb-2">
          <% flash[:refresh_added].each do |name| %>
            <li><%= name %></li>
          <% end %>
        </ul>
      <% end %>
      <% if flash[:refresh_removed].present? %>
        <strong>Entfernt:</strong>
        <ul class="mb-0">
          <% flash[:refresh_removed].each do |name| %>
            <li><%= name %></li>
          <% end %>
        </ul>
      <% end %>
    <% end %>
  </div>
<% end %>

<%# String-Keys ("name"/"provider"/"reason") noetig, nicht Symbole: der Flash haelt die Hashes
    aus DownloadResultParser ueber den Redirect hinweg in der Session, deren cookies_serializer
    auf :json steht - Symbol-Keys werden dabei zu Strings. %>
<% if flash[:download_added] || flash[:download_failed] %>
  <div class="alert alert-info mt-3">
    <% if flash[:download_added].present? %>
      <strong>Heruntergeladen:</strong>
      <ul class="mb-2">
        <% flash[:download_added].each do |entry| %>
          <li><%= entry["name"] %> (<%= entry["provider"] %>)</li>
        <% end %>
        <% if flash[:download_added_total].to_i > flash[:download_added].size %>
          <li>… und <%= flash[:download_added_total] - flash[:download_added].size %> weitere</li>
        <% end %>
      </ul>
    <% end %>
    <% if flash[:download_failed].present? %>
      <strong>Fehlgeschlagen:</strong>
      <ul class="mb-0">
        <% flash[:download_failed].each do |entry| %>
          <li><%= entry["name"] %> — <%= entry["reason"] %></li>
        <% end %>
        <% if flash[:download_failed_total].to_i > flash[:download_failed].size %>
          <li>… und <%= flash[:download_failed_total] - flash[:download_failed].size %> weitere</li>
        <% end %>
      </ul>
    <% end %>
  </div>
<% end %>
<div class="table-responsive rounded border">
  <table class="table table-hover align-middle mb-0 table-tracks table-tracks-detailed">
    <thead class="table-light">
    <tr>
      <th scope="col" class="col-name">Name</th>
      <% if column_visible?("duration") %>
        <th scope="col" class="text-end col-duration">Dauer</th>
      <% end %>
      <% if column_visible?("added_at") %>
        <th scope="col" class="col-added_at">hinzugefügt</th>
      <% end %>
      <% if column_visible?("genre") %>
        <th scope="col" class="col-genre">Genre</th>
      <% end %>
      <% if column_visible?("popularity") %>
        <th scope="col" class="col-popularity">Bekanntheit</th>
      <% end %>
      <% if column_visible?("energy") %>
        <th scope="col" class="col-energy">Energie</th>
      <% end %>
      <% if column_visible?("tempo") %>
        <th scope="col" class="text-end col-tempo">Tempo</th>
      <% end %>
      <% if column_visible?("artist") %>
        <th scope="col" class="col-artist">Künstler</th>
      <% end %>
      <% if column_visible?("album") %>
        <th scope="col" class="col-album">Album Name</th>
      <% end %>
      <% if column_visible?("release_date") %>
        <th scope="col" class="col-release_date">Veröffentlichung</th>
      <% end %>
      <% if column_visible?("playlists") %>
        <th scope="col" class="col-playlists">Playlists</th>
      <% end %>
      <% if column_visible?("tags") %>
        <th scope="col" class="col-tags">Tags</th>
      <% end %>
      <% if column_visible?("file") %>
        <th scope="col" class="col-file">Datei</th>
      <% end %>
      <%# p.album.genres.join(", ") Teuer!!%>
    </tr>
    </thead>
    <tbody>
      <%# Explizite locals noetig statt der kurzen render @playlist_tracks-Form (Intent 89) - die
          Partial rendert die Tags-Spalte jetzt ueber dieselbe tracks/tag_cell wie tracks/_track.erb,
          die ein recent_tags-Local erwartet. %>
      <%= render partial: "playlist_tracks/playlist_track", collection: @playlist_tracks,
                 as: :playlist_track, locals: { recent_tags: @recent_tag_suggestions } %>
    </tbody>
  </table>
</div>
