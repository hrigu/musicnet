<%# Einzige, dauerhafte Player-Leiste (Intent 40). data-turbo-permanent + stabile id: Turbo Drive
    erkennt das Element anhand der id zwischen altem und neuem Dokument und uebernimmt den
    bestehenden DOM-Knoten (inkl. laufender Wiedergabe) unveraendert, statt ihn bei einem
    Seitenwechsel zu ersetzen. Liegt ausserdem ausserhalb von turbo_frame_tag "tracks" - eine
    Suche/Sortierung dort ersetzt nur den Frame-Inhalt, dieses Element wird gar nicht beruehrt.
    Die Song-Queue (Intent 41, seit Intent 42 in der DB statt in JS) lebt zwar im selben
    permanenten Element, ist aber unabhaengig davon korrekt: sie wird nicht durch Turbos
    Permanent-Element-Mechanik aktuell gehalten, sondern durch echte Server-Rendern +
    Turbo-Stream-Updates (siehe queue_entries_controller.rb) - eine reine Seitennavigation
    veraendert die Queue-Daten ohnehin nicht, das alte, beibehaltene Markup bleibt also korrekt. %>
<%= turbo_stream_from "queue" %>
<div id="global-audio-player" data-turbo-permanent data-controller="audio-player" class="fixed-bottom bg-light border-top">
  <div id="audio-player-queue" class="px-3 small text-muted">
    <div id="audio-player-queue-list">
      <%= render "queue_entries/queue_list" %>
    </div>
  </div>
  <div class="d-flex align-items-center gap-2 px-3 py-2">
    <span title="Hauptkanal">🔊</span>
    <button type="button" class="btn btn-sm btn-outline-secondary rounded-circle" title="Play/Pause"
            data-audio-player-target="toggleButton" data-action="audio-player#toggle">
      <span data-audio-player-target="icon">▶</span>
    </button>
    <a data-audio-player-target="name" href="#" class="text-truncate flex-grow-1">–</a>
    <span data-audio-player-target="currentTime" class="small text-muted">0:00</span>
    <input type="range" value="0" class="form-range" style="max-width: 150px;"
           data-audio-player-target="progress" data-action="input->audio-player#seek">
    <span data-audio-player-target="duration" class="small text-muted">0:00</span>
    <button type="button" class="btn btn-sm btn-link" data-action="audio-player#chooseOutputDevice"
            data-audio-player-target="chooseButton">
      Ausgabegerät (Hauptkanal)
    </button>
    <select class="form-select form-select-sm w-auto d-none" data-audio-player-target="deviceSelect"
            data-action="audio-player#selectOutputDevice"></select>
    <audio data-audio-player-target="audio" preload="none"></audio>
  </div>
  <%# Cue-/Vorhoerkanal (Intent 51): eigener, unabhaengiger <audio>-Kanal - unterbricht die
      Queue-Wiedergabe oben nicht. Bewusst minimal (kein Seek-Balken) fuer eine erste Version. %>
  <div class="d-flex align-items-center gap-2 px-3 py-1 border-top small" data-controller="cue-player">
    <span title="Vorhörkanal">🎧</span>
    <button type="button" class="btn btn-sm btn-outline-secondary rounded-circle" title="Play/Pause (Vorhören)"
            data-cue-player-target="toggleButton" data-action="cue-player#toggle">
      <span data-cue-player-target="icon">▶</span>
    </button>
    <a data-cue-player-target="name" href="#" class="text-truncate flex-grow-1">–</a>
    <button type="button" class="btn btn-sm btn-link ms-auto" data-action="cue-player#chooseOutputDevice"
            data-cue-player-target="chooseButton">
      Ausgabegerät (Vorhören)
    </button>
    <select class="form-select form-select-sm w-auto d-none" data-cue-player-target="deviceSelect"
            data-action="cue-player#selectOutputDevice"></select>
    <audio data-cue-player-target="audio" preload="none"></audio>
  </div>
</div>
