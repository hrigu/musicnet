<%= form_with model: tag, url: (tag.persisted? ? tag_path(tag) : category_tags_path(@category)), local: true do |f| %>
  <% if tag.errors.any? %>
    <div class="alert alert-danger">
      <%= tag.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :category_id, "Kategorie", class: "form-label" %>
    <%= f.collection_select :category_id, Category.order(:name), :id, :name, {}, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :aliases, "Alias-Stichwörter", class: "form-label" %>
    <%= f.text_field :aliases, class: "form-control" %>
    <div class="form-text">
      Kommagetrennte Stichwörter, die in Playlist-Namen auf diesen Tag hindeuten
      (gross-/kleinschreibungsunabhängig), z.B. "traurig, melancholisch, sad".
    </div>
  </div>

  <div class="form-check mb-3">
    <%= f.check_box :assignable, class: "form-check-input" %>
    <%= f.label :assignable, "Für neue Vergaben erlauben", class: "form-check-label" %>
    <div class="form-text">
      Wenn deaktiviert, bleibt das Tag sichtbar und bestehende Zuordnungen bleiben erhalten,
      kann aber nicht mehr neu vergeben werden.
    </div>
  </div>

  <%= f.submit "Speichern", class: "btn btn-outline-secondary" %>
<% end %>
